{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "T3CODE_LOG_WS_EVENTS",
    "T3CODE_PORT",
    "T3CODE_HOME",
    "T3CODE_AUTH_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "dist-electron/**"
      ]
    },
    "dev": {
      "dependsOn": [
        "@t3tools/contracts#build"
      ],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "outputs": []
    }
  }
}
