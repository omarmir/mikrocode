{
  "expo": {
    "name": "mikrocode",
    "slug": "mikrocode",
    "scheme": "mikrocode",
    "icon": "../../assets/prod/mikrocode-icon-1024.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow mikrocode to access your photos so you can send images to the model.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "android": {
      "package": "com.mikrocode",
      "adaptiveIcon": {
        "foregroundImage": "../../assets/prod/mikrocode-adaptive-foreground.png",
        "backgroundColor": "#100F0F"
      }
    }
  }
}
